{
  "name": "figmakit-prep",
  "version": "1.0.0",
  "private": true,
  "description": "Prepare your Figma files for FigmaKit — clean layers, rename nodes, validate structure, and preview exports before syncing to WordPress",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.106.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
